# SoloLedger Cloud — secrets (copy to .env, fill in)

# Stripe (for payment links / checkout)
STRIPE_SECRET_KEY=

# Plaid (for automated bank feeds)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ACCESS_TOKEN=
PLAID_ENV=sandbox

# Toggl (for time tracking)
TOGGL_API_TOKEN=

# Email notifications
NOTIFY_SMTP_PASSWORD=

# PoolSplat — fal.ai API key for AI photo editing
# Get one at https://fal.ai/dashboard
FAL_KEY=

# Netdata — email alerts (optional, uses sendmail)
# If unset, Netdata runs without email notifications
NETDATA_EMAIL_SEND=
# NETDATA_EMAIL_TO=dillon@ferrumengineeringllc.com
