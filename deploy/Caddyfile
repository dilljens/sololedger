# Ferrum Engineering — shared reverse proxy config
#
# Each project has its own config snippet in sites/*.conf.
# Add a new project by creating sites/<project>.conf, then:
#   docker compose -f /opt/sololedger/deploy/docker-compose.yml restart caddy
#
# ⚠️ NEVER edit the Caddyfile directly on the server.
# Changes to existing snippets MUST go through git
# so they survive the next git pull.
#
# Order matters: Caddy evaluates site blocks in declaration order.
# The import glob loads snippets in alphabetical order.

import sites/*.conf
